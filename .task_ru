#include "link/tcp_link.h"

class Pipeline {
public:
    explicit Pipeline(SaiInterface& sai);

    void process(Packet& pkt);
    void set_link(TcpLink* link);

private:
    L2Service l2_;
    L3Service l3_;
    TcpLink* link_{nullptr};
};
```

---

## dataplane/pipeline.cpp

```cpp
void Pipeline::set_link(TcpLink* link) {
    link_ = link;
}

void Pipeline::process(Packet& pkt) {
    if (l2_.handle(pkt)) return;

    if (l3_.handle(pkt)) {
        if (link_) {
            std::cout << "[LINK] Forwarding to peer\n";
            link_->send(pkt);
        }
        return;
    }

    std::cout << "[DROP]\n";
}
```

