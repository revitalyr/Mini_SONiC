---

### Pipeline:

```cpp
void Pipeline::process(Packet& pkt) {
    if (l2_.handle(pkt)) return;
    if (l3_.handle(pkt)) return;

    drop(pkt);
}
```

---

# 🔁 5. L2 switching

```cpp
bool L2Service::handle(Packet& pkt) {
    mac_table_.learn(pkt.src_mac, pkt.ingress_port);

    auto out_port = mac_table_.lookup(pkt.dst_mac);
    if (out_port) {
        forward(pkt, *out_port);
        return true;
    }

    flood(pkt);
    return true;
}
```

