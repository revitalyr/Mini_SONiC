# 📦 2. Metrics registry (thread-safe)

## src/utils/metrics.h

```cpp
#pragma once

#include <atomic>
#include <string>
#include <unordered_map>

class Metrics {
public:
    static Metrics& instance() {
        static Metrics m;
        return m;
    }

    void inc(const std::string& key) {
        counters_[key]++;
    }

    void add_latency(uint64_t us) {
        latency_sum_ += us;
        latency_count_++;
    }

    std::string dump() {
        std::string out;

        for (auto& [k, v] : counters_) {
            out += k + " " + std::to_string(v.load()) + "\n";
        }

        if (latency_count_ > 0) {
            uint64_t avg = latency_sum_ / latency_count_;
            out += "avg_latency_us " + std::to_string(avg) + "\n";
        }

        return out;
    }

private:
    std::unordered_map<std::string, std::atomic<uint64_t>> counters_;
    std::atomic<uint64_t> latency_sum_{0};
    std::atomic<uint64_t> latency_count_{0};
};
```

---

