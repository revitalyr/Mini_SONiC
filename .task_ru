# 📦 1. Добавим HTTP сервер в C++

Минимально — без тяжелых зависимостей.

## src/api/http_server.h

```cpp
#pragma once

#include <functional>
#include <string>
#include <thread>
#include <atomic>

class HttpServer {
public:
    using RouteHandler = std::function<std::string(const std::string& body)>;

    HttpServer(int port);

    void start();
    void stop();

    void set_route_handler(RouteHandler handler);

private:
    void run();

    int port_;
    std::atomic<bool> running_{false};
    std::thread server_thread_;

    RouteHandler route_handler_;
};
```

---

## src/api/http_server.cpp (очень упрощённый)

```cpp
#include "api/http_server.h"
#include <iostream>
#include <netinet/in.h>
#include <unistd.h>

HttpServer::HttpServer(int port) : port_(port) {}

void HttpServer::set_route_handler(RouteHandler handler) {
    route_handler_ = handler;
}

void HttpServer::start() {
    running_ = true;
    server_thread_ = std::thread(&HttpServer::run, this);
}

void HttpServer::stop() {
    running_ = false;
    if (server_thread_.joinable())
        server_thread_.join();
}

void HttpServer::run() {
    int server_fd = socket(AF_INET, SOCK_STREAM, 0);

    sockaddr_in addr{};
    addr.sin_family = AF_INET;
    addr.sin_port = htons(port_);
    addr.sin_addr.s_addr = INADDR_ANY;

    bind(server_fd, (sockaddr*)&addr, sizeof(addr));
    listen(server_fd, 10);

    std::cout << "[HTTP] Listening on port " << port_ << "\n";

    while (running_) {
        int client = accept(server_fd, nullptr, nullptr);

        char buffer[1024] = {0};
        read(client, buffer, 1024);

        std::string request(buffer);

        std::string response_body = route_handler_
            ? route_handler_(request)
            : "OK";

        std::string response =
            "HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\n\r\n" +
            response_body;

        send(client, response.c_str(), response.size(), 0);
        close(client);
    }
}
```

