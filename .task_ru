# 📦 2. Сериализация пакета

## dataplane/packet.h (обновляем)

```cpp
#pragma once
#include <string>
#include <sstream>

struct Packet {
    std::string src_mac;
    std::string dst_mac;
    std::string src_ip;
    std::string dst_ip;
    int ingress_port;

    std::string serialize() const {
        std::ostringstream ss;
        ss << src_mac << ","
           << dst_mac << ","
           << src_ip << ","
           << dst_ip << ","
           << ingress_port;
        return ss.str();
    }

    static Packet deserialize(const std::string& data) {
        std::stringstream ss(data);
        Packet pkt;
        std::getline(ss, pkt.src_mac, ',');
        std::getline(ss, pkt.dst_mac, ',');
        std::getline(ss, pkt.src_ip, ',');
        std::getline(ss, pkt.dst_ip, ',');
        ss >> pkt.ingress_port;
        return pkt;
    }
};
```

---

# 🔗 3. TCP Link

## link/tcp_link.h

```cpp
#pragma once

#include "dataplane/packet.h"
#include <thread>
#include <atomic>
#include <functional>

class TcpLink {
public:
    using PacketHandler = std::function<void(Packet)>;

    TcpLink(int listen_port, const std::string& peer_ip, int peer_port);

    void start();
    void stop();

    void send(const Packet& pkt);

    void set_handler(PacketHandler handler);

private:
    void run_server();
    void run_client();

    int listen_port_;
    std::string peer_ip_;
    int peer_port_;

    int sock_{-1};

    std::atomic<bool> running_{false};
    std::thread server_thread_;
    std::thread client_thread_;

    PacketHandler handler_;
};
```

---

## link/tcp_link.cpp

```cpp
#include "link/tcp_link.h"
#include <netinet/in.h>
#include <arpa/inet.h>
#include <unistd.h>
#include <iostream>

TcpLink::TcpLink(int listen_port,
                 const std::string& peer_ip,
                 int peer_port)
    : listen_port_(listen_port),
      peer_ip_(peer_ip),
      peer_port_(peer_port) {}

void TcpLink::set_handler(PacketHandler handler) {
    handler_ = handler;
}

void TcpLink::start() {
    running_ = true;
    server_thread_ = std::thread(&TcpLink::run_server, this);
    client_thread_ = std::thread(&TcpLink::run_client, this);
}

void TcpLink::stop() {
    running_ = false;
}

void TcpLink::run_server() {
    int server_fd = socket(AF_INET, SOCK_STREAM, 0);

    sockaddr_in addr{};
    addr.sin_family = AF_INET;
    addr.sin_port = htons(listen_port_);
    addr.sin_addr.s_addr = INADDR_ANY;

    bind(server_fd, (sockaddr*)&addr, sizeof(addr));
    listen(server_fd, 5);

    while (running_) {
        int client = accept(server_fd, nullptr, nullptr);

        char buffer[1024];
        int len = read(client, buffer, sizeof(buffer));

        if (len > 0) {
            std::string data(buffer, len);
            Packet pkt = Packet::deserialize(data);

            if (handler_) handler_(pkt);
        }

        close(client);
    }
}

void TcpLink::run_client() {
    while (running_) {
        sock_ = socket(AF_INET, SOCK_STREAM, 0);

        sockaddr_in addr{};
        addr.sin_family = AF_INET;
        addr.sin_port = htons(peer_port_);
        inet_pton(AF_INET, peer_ip_.c_str(), &addr.sin_addr);

        if (connect(sock_, (sockaddr*)&addr, sizeof(addr)) == 0) {
            std::cout << "[LINK] Connected to peer\n";
            break;
        }

        sleep(1);
    }
}

void TcpLink::send(const Packet& pkt) {
    if (sock_ < 0) return;

    std::string data = pkt.serialize();
    ::send(sock_, data.c_str(), data.size(), 0);
}
```

