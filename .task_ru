# 🔁 4. Pipeline instrumentation

## dataplane/pipeline.cpp

```cpp
#include "utils/metrics.h"

void Pipeline::process(Packet& pkt) {
    auto& m = Metrics::instance();

    m.inc("packets_total");

    if (l2_.handle(pkt)) {
        m.inc("packets_l2");
        return;
    }

    if (l3_.handle(pkt)) {
        m.inc("packets_l3");

        if (link_) {
            m.inc("packets_forwarded");
            link_->send(pkt);
        }

        return;
    }

    m.inc("packets_dropped");
}
```

