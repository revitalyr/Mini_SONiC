```python
import requests
import sys

BASE = "http://localhost:8080"

def add_route(prefix, mask, nh):
    requests.post(f"{BASE}/route",
                  data=f"{prefix} {mask} {nh}")

def main():
    while True:
        cmd = input("mini-sonic> ")

        if cmd.startswith("add route"):
            _, _, prefix, nh = cmd.split()
            ip, mask = prefix.split("/")

            add_route(ip, mask, nh)

        elif cmd == "exit":
            break

if __name__ == "__main__":
    main()
```

