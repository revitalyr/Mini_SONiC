#include "l3/lpm_trie.h"

class L3Service {
public:
    explicit L3Service(SaiInterface& sai);

    bool handle(Packet& pkt);

    void add_route(const std::string& prefix,
                   int prefix_len,
                   const std::string& next_hop);

private:
