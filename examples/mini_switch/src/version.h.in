/**
 * @file version.h.in
 * @brief SONiC Mini Switch Version Information
 * 
 * This file is automatically generated by CMake
 * and contains version information for the build.
 */

#ifndef SONIC_VERSION_H
#define SONIC_VERSION_H

#define SONIC_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define SONIC_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define SONIC_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define SONIC_VERSION_TWEAK @PROJECT_VERSION_TWEAK@

#define SONIC_VERSION_STRING "@PROJECT_VERSION@"
#define SONIC_VERSION_FULL "@PROJECT_VERSION_FULL@"
#define SONIC_DESCRIPTION "@PROJECT_DESCRIPTION@"

#define SONIC_BUILD_TYPE "@CMAKE_BUILD_TYPE@"
#define SONIC_COMPILER_ID "@CMAKE_C_COMPILER_ID@"
#define SONIC_COMPILER_VERSION "@CMAKE_C_COMPILER_VERSION@"

#define SONIC_BUILD_TIMESTAMP __DATE__ " " __TIME__

// Version comparison macro
#define SONIC_VERSION_CHECK(major, minor, patch) \
    ((SONIC_VERSION_MAJOR > (major)) || \
     (SONIC_VERSION_MAJOR == (major) && SONIC_VERSION_MINOR > (minor)) || \
     (SONIC_VERSION_MAJOR == (major) && SONIC_VERSION_MINOR == (minor) && SONIC_VERSION_PATCH >= (patch)))

#endif // SONIC_VERSION_H
