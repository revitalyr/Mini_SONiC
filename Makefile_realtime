# =============================================================================
# SONiC Mini Switch - Real-time Demo Makefile
# =============================================================================

CC = gcc
CFLAGS = -Wall -Wextra -O2 -std=c99
TARGET = realtime_demo

# Source files
SOURCES = src/realtime_demo.c

# Default target
all: $(TARGET)

# Clean target
clean:
	rm -f $(TARGET) *.o

# Install target (optional)
install: $(TARGET)
	@echo "Installing $(TARGET) to /usr/local/bin/..."
	cp $(TARGET) /usr/local/bin/

# Run target (default)
run: $(TARGET)
	@echo "Running SONiC Mini Switch Real-time Demo..."
	./$(TARGET)

.PHONY: clean install run
